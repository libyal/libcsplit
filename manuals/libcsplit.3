.Dd June 24, 2026
.Dt LIBCSPLIT 3
.Os
.Sh NAME
.Nm libcsplit.h
.Nd Library to support cross-platform C split string functions
.Sh SYNOPSIS
.In libcsplit.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libcsplit_get_version
.Fa "void"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libcsplit_error_free
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_error_fprint
.Fa "libcsplit_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_error_sprint
.Fa "libcsplit_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_error_backtrace_fprint
.Fa "libcsplit_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_error_backtrace_sprint
.Fa "libcsplit_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
Narrow string functions
.nf
.Ft int
.Fo libcsplit_narrow_string_split
.Fa "const char *string"
.Fa "size_t string_size"
.Fa "char delimiter"
.Fa "libcsplit_narrow_split_string_t **split_string"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.Pp
Narrow split string functions
.nf
.Ft int
.Fo libcsplit_narrow_split_string_free
.Fa "libcsplit_narrow_split_string_t **split_string"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_narrow_split_string_get_string
.Fa "libcsplit_narrow_split_string_t *split_string"
.Fa "char **string"
.Fa "size_t *string_size"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_narrow_split_string_get_number_of_segments
.Fa "libcsplit_narrow_split_string_t *split_string"
.Fa "int *number_of_segments"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_narrow_split_string_get_segment_by_index
.Fa "libcsplit_narrow_split_string_t *split_string"
.Fa "int segment_index"
.Fa "char **string_segment"
.Fa "size_t *string_segment_size"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_narrow_split_string_set_segment_by_index
.Fa "libcsplit_narrow_split_string_t *split_string"
.Fa "int segment_index"
.Fa "char *string_segment"
.Fa "size_t string_segment_size"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.Pp
Wide string functions
.nf
.Ft int
.Fo libcsplit_wide_string_split
.Fa "const wchar_t *string"
.Fa "size_t string_size"
.Fa "wchar_t delimiter"
.Fa "libcsplit_wide_split_string_t **split_string"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.Pp
Wide split string functions
.nf
.Ft int
.Fo libcsplit_wide_split_string_free
.Fa "libcsplit_wide_split_string_t **split_string"
.Fa "libcsplit_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcsplit_wide_split_string_get_string
.Fa "libcsplit_wide_split_string_t *split_string"
